---
// CHIMERA AI — Nasıl Başlarız (Bronz varsayılan). Kaynak: chimera-sections-b.jsx (StartSection)
import Frame from "../Frame.astro";
import type { Dict } from "@i18n/tr";

interface Props {
  t: Dict;
}
const { t } = Astro.props;
---

<section id="nasil-baslariz" class="section">
  <div class="wrap" style="display:flex;flex-direction:column;gap:44px">
    <div style="max-width:620px;display:flex;flex-direction:column;gap:18px">
      <div class="mono-label">{t.start.label}</div>
      <h2 class="h-section">{t.start.h2}</h2>
      <p class="lede">{t.start.lede}</p>
    </div>
    <div class="grid-3">
      {
        t.start.steps.map((s) => (
          <div class="card">
            <span style="font-family:var(--font-mono);font-size:11.5px;letter-spacing:0.08em;color:var(--bronze-on-dark)">
              {s.k}
            </span>
            <h3 class="h-card">{s.t}</h3>
            <p class="body-dim" style="font-size:calc(15.5px * var(--ts))">{s.d}</p>
          </div>
        ))
      }
    </div>
    <div style="display:flex;align-items:center;gap:28px;flex-wrap:wrap;justify-content:space-between">
      <Frame style="padding:20px 26px;display:flex;gap:20px;align-items:center;flex:1 1 460px">
        <span style="font-family:var(--font-mono);font-size:11.5px;letter-spacing:0.08em;color:var(--bronze-on-dark);flex:none">
          {t.start.kobiK}
        </span>
        <div>
          <span style="font-weight:600">{t.start.kobiT}</span>
          <span class="body-dim" style="font-size:calc(15px * var(--ts))"> — {t.start.kobiD}</span>
        </div>
      </Frame>
      <a class="btn btn-primary" href="#iletisim">{t.start.cta}</a>
    </div>
  </div>
</section>
