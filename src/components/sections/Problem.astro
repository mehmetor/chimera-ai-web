---
// CHIMERA AI — Sorun. Kaynak: chimera-sections-a.jsx (ProblemSection)
import type { Dict } from "@i18n/tr";
interface Props {
  t: Dict;
}
const { t } = Astro.props;
---

<section id="sorun" class="section on-light">
  <div class="wrap" style="display:flex;flex-direction:column;gap:40px">
    <div style="max-width:660px;display:flex;flex-direction:column;gap:18px">
      <div class="mono-label">{t.problem.label}</div>
      <h2 class="h-section">{t.problem.h2}</h2>
      <p class="lede">{t.problem.lede}</p>
    </div>
    <div class="grid-3">
      {
        t.problem.items.map((it) => (
          <div class="card">
            <span style="font-family:var(--font-mono);font-size:11.5px;font-weight:500;letter-spacing:0.08em;color:var(--accent-ink)">
              {it.k}
            </span>
            <h3 class="h-card">{it.t}</h3>
            <p class="body-dim" style="font-size:calc(15.5px * var(--ts))">{it.d}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
