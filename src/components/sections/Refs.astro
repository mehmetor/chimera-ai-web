---
// CHIMERA AI — Referanslar. Kaynak: chimera-sections-b.jsx (RefsSection)
import type { Dict } from "@i18n/tr";
interface Props {
  t: Dict;
}
const { t } = Astro.props;
---

<section id="referanslar" class="section on-light">
  <div class="wrap" style="display:flex;flex-direction:column;gap:40px">
    <div style="max-width:620px;display:flex;flex-direction:column;gap:18px">
      <div class="mono-label">{t.refs.label}</div>
      <h2 class="h-section">{t.refs.h2}</h2>
      <p class="body-dim" style="font-size:calc(15px * var(--ts))">{t.refs.lede}</p>
    </div>
    <div class="grid-2" style="grid-template-columns:1fr 1fr;gap:20px">
      <div style="display:flex;flex-direction:column;gap:16px">
        {
          t.refs.items.map((it) => (
            <div class="card" style="gap:8px">
              <span
                style={`font-family:var(--font-mono);font-size:11.5px;letter-spacing:0.08em;color:${it.state === "ok" ? "var(--ok)" : "var(--warn)"};display:flex;align-items:center;gap:8px`}
              >
                <span style="width:7px;height:7px;background:currentColor;flex:none" />
                {it.k}
              </span>
              <h3 class="h-card" style="font-size:calc(18px * var(--ts))">{it.t}</h3>
              <p class="body-dim" style="font-size:calc(15px * var(--ts))">{it.d}</p>
            </div>
          ))
        }
      </div>
      <div class="duotone" style="min-height:320px">
        <div class="duo-placeholder" style="height:100%;min-height:320px">{t.refs.photoPlaceholder}</div>
        <span class="duo-caption">{t.refs.photoCaption}</span>
      </div>
    </div>
  </div>
</section>
