---
// CHIMERA AI — site navigasyonu (sticky). Kaynak: chimera-sections-a.jsx (SiteNav)
// Linkler merkezî route haritasından (yerelleştirilmiş slug'lar).
import SealMark from "./SealMark.astro";
import type { Lang } from "@i18n/utils";
import { navItems, contactSlug, homeSlug, hreflangFor, type RouteKey } from "@i18n/routes";
import type { Dict } from "@i18n/tr";

interface Props {
  lang: Lang;
  t: Dict;
  routeKey?: RouteKey | "home";
}
const { lang, t, routeKey = "home" } = Astro.props;

const home = homeSlug(lang);
const items = navItems(lang);
const cta = contactSlug(lang);
const current = Astro.url.pathname.replace(/\/$/, "") || "/";
const pair = hreflangFor(routeKey);
---

<nav class="nav">
  <div class="nav-inner">
    <a class="brand-lockup" href={home} aria-label="Chimera AI — ana sayfa">
      <SealMark size={30} variant="dugum" color="var(--n-100)" />
      <span class="brand-word">CHIMERA <span class="ai">AI</span></span>
    </a>
    <div class="nav-links">
      {
        items.map((it) => (
          <a class="nav-link" href={it.href} aria-current={current === it.href.replace(/\/$/, "") ? "page" : undefined}>
            {it.label}
          </a>
        ))
      }
      <a class="nav-cta" href={cta} style="margin-left:8px">{t.nav.cta}</a>
      <div class="lang-switch">
        <a class={lang === "tr" ? "active" : ""} href={pair.tr} hreflang="tr">TR</a>
        <a class={lang === "en" ? "active" : ""} href={pair.en} hreflang="en">EN</a>
      </div>
    </div>
  </div>
</nav>
