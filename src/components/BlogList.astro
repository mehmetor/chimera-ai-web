---
// CHIMERA AI — blog indeks listesi (yazı kartları → makale). Boşsa "yakında" durumu.
import { getBlog, entrySlug } from "@/lib/content";
import type { Lang } from "@i18n/utils";

interface Props {
  lang: Lang;
  basePath: string;
  emptyLabel: string;
}
const { lang, basePath, emptyLabel } = Astro.props;
const posts = await getBlog(lang);
const fmt = (d: Date) => d.toLocaleDateString(lang === "tr" ? "tr-TR" : "en-US", { year: "numeric", month: "long", day: "numeric" });
---

{
  posts.length === 0 ? (
    <p class="body-dim">{emptyLabel}</p>
  ) : (
    <div style="display:flex;flex-direction:column;gap:16px;max-width:820px">
      {posts.map((p) => (
        <a class="card" href={`${basePath}/${entrySlug(p.id)}`} style="gap:8px;text-decoration:none;color:inherit">
          <span style="font-family:var(--font-mono);font-size:11.5px;letter-spacing:0.06em;color:var(--n-500)">
            {fmt(p.data.pubDate)}
          </span>
          <h3 class="h-card" style="font-size:calc(19px * var(--ts))">{p.data.title}</h3>
          <p class="body-dim" style="font-size:calc(15px * var(--ts))">{p.data.description}</p>
        </a>
      ))}
    </div>
  )
}
