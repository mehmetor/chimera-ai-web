---
// CHIMERA AI — mühür-işaret (üç yay segmenti + kare düğümler = tam kapalı halka)
// Kaynak: design/prototype/chimera-mark.jsx — geometri build-time hesaplanır, client JS YOK.
// Kapanış animasyonu saf CSS (base.css: .seal-anim/.seal-go + prefers-reduced-motion fallback).
type Accent = "platform" | "devops" | "app" | null;
type Variant = "denge" | "cimasi" | "dugum";

interface Props {
  size?: number;
  variant?: Variant;
  accent?: Accent;
  color?: string;
  animate?: boolean;
  class?: string;
}

const {
  size = 48,
  variant = "denge",
  accent = null,
  color = "currentColor",
  animate = false,
  class: className = "",
} = Astro.props;

// İşçilik varyantları (Brief §5 adım 2: segment oranı / düğüm / C-iması)
const SEAL_VARIANTS: Record<Variant, { spans: number[]; strokes: number[]; node: number; gap: number }> = {
  denge: { spans: [138, 117, 105], strokes: [9, 9, 9], node: 14, gap: 10 },
  cimasi: { spans: [172, 108, 80], strokes: [11, 8, 8], node: 14, gap: 11 },
  dugum: { spans: [128, 120, 112], strokes: [8, 8, 8], node: 17, gap: 13 },
};

function polar(cx: number, cy: number, r: number, deg: number): [number, number] {
  const a = ((deg - 90) * Math.PI) / 180;
  return [cx + r * Math.cos(a), cy + r * Math.sin(a)];
}
function arcPath(cx: number, cy: number, r: number, a0: number, a1: number): string {
  const [x0, y0] = polar(cx, cy, r, a0);
  const [x1, y1] = polar(cx, cy, r, a1);
  const large = a1 - a0 > 180 ? 1 : 0;
  return `M ${x0.toFixed(2)} ${y0.toFixed(2)} A ${r} ${r} 0 ${large} 1 ${x1.toFixed(2)} ${y1.toFixed(2)}`;
}

const v = SEAL_VARIANTS[variant] ?? SEAL_VARIANTS.denge;
const cx = 50;
const cy = 50;
const r = 36;

const accentMap: Record<"platform" | "devops" | "app", string> = {
  platform: "var(--bronze)",
  devops: "var(--steel)",
  app: "var(--terra)",
};
const keys = ["platform", "devops", "app"] as const;
const segColors = keys.map((k) => (accent === k ? accentMap[k] : color));

let a = 0;
const bounds = [0];
v.spans.forEach((s) => {
  a += s;
  bounds.push(a);
});
const total = bounds[3]; // 360
const scale = 360 / total;

const arcs = v.spans.map((_span, i) => {
  const a0 = bounds[i] * scale + v.gap / 2;
  const a1 = bounds[i + 1] * scale - v.gap / 2;
  return { d: arcPath(cx, cy, r, a0, a1), w: v.strokes[i], c: segColors[i] };
});
const nodes = bounds.slice(0, 3).map((b, i) => {
  const ang = b * scale;
  const [x, y] = polar(cx, cy, r, ang);
  const fill = accent && keys[i] === accent ? accentMap[accent] : color;
  return { x, y, ang, fill };
});

const wrapperClass = [animate ? "seal-anim seal-go" : "", className].filter(Boolean).join(" ");
---

<svg
  width={size}
  height={size}
  viewBox="0 0 100 100"
  class={wrapperClass}
  role="img"
  aria-label="Chimera AI"
>
  {arcs.map((p) => <path class="seal-arc" d={p.d} stroke={p.c} stroke-width={p.w} pathLength="1" />)}
  {
    nodes.map((n) => (
      <rect
        class="seal-node"
        x={n.x - v.node / 2}
        y={n.y - v.node / 2}
        width={v.node}
        height={v.node}
        fill={n.fill}
        transform={`rotate(${n.ang} ${n.x} ${n.y})`}
      />
    ))
  }
</svg>
