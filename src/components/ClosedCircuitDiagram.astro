---
// CHIMERA AI — kapalı devre master diyagramı (Brief §3.3)
// Kurum sınırı = kalın kapalı hat; içeride bileşen kutuları; dışarıda kesik
// çizgili bulut + kesilmiş bağlantı. Kaynak: design/prototype/chimera-mark.jsx.
// Sabit yapı, build-time; animate → hat çizilip mühürlenir (saf CSS).
interface DiagramText {
  boundary: string;
  model: string;
  modelSub: string;
  rag: string;
  ragSub: string;
  users: string;
  usersSub: string;
  cloud: string;
  noLink: string;
}
interface Props {
  t: DiagramText;
  dark?: boolean;
  animate?: boolean;
}
const { t, dark = false, animate = false } = Astro.props;

const ink = dark ? "var(--n-100)" : "var(--n-800)";
const dim = dark ? "var(--n-400)" : "var(--n-500)";
const acc = dark ? "var(--bronze-on-dark)" : "var(--bronze-ink)";
const boxBg = dark ? "rgba(232,227,215,0.04)" : "rgba(21,19,14,0.03)";
const bgFill = dark ? "var(--bg-dark)" : "var(--bg-light)";
const terra = dark ? "var(--terra-on-dark)" : "var(--terra)";

const boxes = [
  { x: 70, y: 90, w: 180, h: 78, title: t.model, sub: t.modelSub },
  { x: 70, y: 240, w: 180, h: 78, title: t.rag, sub: t.ragSub },
  { x: 300, y: 165, w: 180, h: 78, title: t.users, sub: t.usersSub },
];
const corners = [
  [24, 110],
  [544, 110],
  [24, 300],
  [544, 300],
];
const cls = animate ? "seal-anim seal-go" : "";
---

<svg
  viewBox="0 0 760 400"
  style="width:100%;height:auto;display:block"
  role="img"
  aria-label={t.boundary}
  class={cls}
>
  {/* kurum sınırı — kalın kapalı hat; animate'te hareket imzası */}
  <rect
    class="seal-arc"
    pathLength="1"
    x="24"
    y="40"
    width="520"
    height="330"
    rx="10"
    fill="none"
    stroke={acc}
    stroke-width="3"></rect>
  {corners.map(([x, y]) => <rect class="seal-node" x={x - 3} y={y - 3} width="6" height="6" fill={acc} />)}

  <rect x="40" y="26" width="190" height="28" fill={bgFill}></rect>
  <text x="48" y="45" font-family="var(--font-mono)" font-size="12.5" letter-spacing="1.5" fill={acc} font-weight="600">{t.boundary}</text>

  {/* içerideki bileşenler */}
  {
    boxes.map((b) => (
      <g>
        <rect x={b.x} y={b.y} width={b.w} height={b.h} rx="6" fill={boxBg} stroke={ink} stroke-width="1.5" />
        <text x={b.x + b.w / 2} y={b.y + b.h / 2 - 5} text-anchor="middle" font-family="var(--font-mono)" font-size="13" letter-spacing="1" fill={ink} font-weight="600">
          {b.title}
        </text>
        <text x={b.x + b.w / 2} y={b.y + b.h / 2 + 15} text-anchor="middle" font-family="var(--font-mono)" font-size="10.5" letter-spacing="0.5" fill={dim}>
          {b.sub}
        </text>
      </g>
    ))
  }

  {/* iç bağlantılar — 1.5px, kare düğümler */}
  <path d="M 160 168 V 240" stroke={ink} stroke-width="1.5" fill="none"></path>
  <rect x="157" y="201" width="6" height="6" fill={acc}></rect>
  <path d="M 250 129 H 275 V 185 H 300" stroke={ink} stroke-width="1.5" fill="none"></path>
  <path d="M 250 279 H 275 V 223 H 300" stroke={ink} stroke-width="1.5" fill="none"></path>
  <rect x="272" y="154" width="6" height="6" fill={acc}></rect>
  <rect x="272" y="248" width="6" height="6" fill={acc}></rect>

  {/* dış bulut — kesik çizgili, bağlantı kesik */}
  <g opacity="0.75">
    <path
      d="M 622 150 a 22 22 0 0 1 21 -16 a 26 26 0 0 1 50 6 a 18 18 0 0 1 -2 35 h -62 a 19 19 0 0 1 -7 -25 z"
      fill="none"
      stroke={dim}
      stroke-width="1.5"
      stroke-dasharray="5 5"></path>
    <text x="676" y="208" text-anchor="middle" font-family="var(--font-mono)" font-size="11.5" letter-spacing="1" fill={dim}>{t.cloud}</text>
  </g>
  {/* kesilmiş bağlantı */}
  <path d="M 544 205 H 590" stroke={dim} stroke-width="1.5" stroke-dasharray="5 5"></path>
  <path d="M 600 196 l 16 18 M 616 196 l -16 18" stroke={terra} stroke-width="2"></path>
  <path d="M 626 205 H 656" stroke={dim} stroke-width="1.5" stroke-dasharray="5 5" opacity="0.5"></path>
  <text x="608" y="240" text-anchor="middle" font-family="var(--font-mono)" font-size="10.5" letter-spacing="1" fill={terra}>{t.noLink}</text>
</svg>
