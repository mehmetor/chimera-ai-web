---
// CHIMERA AI — Glossary index (EN). Plain-language enterprise AI terms (GEO, IA §4.2).
import Base from "@layouts/Base.astro";
import GlossaryIndex from "@components/GlossaryIndex.astro";
---

<Base
  title="Glossary — Enterprise AI terms · Chimera AI"
  description="From RAG to closed circuit — plain-language explanations of enterprise AI terms."
>
  <section class="section on-light">
    <div class="wrap" style="display:flex;flex-direction:column;gap:32px">
      <div style="max-width:680px;display:flex;flex-direction:column;gap:16px">
        <div class="mono-label">Resources · Glossary</div>
        <h1 class="h-section">Enterprise AI glossary</h1>
        <p class="lede">Key terms explained in plain language — definition plus examples.</p>
      </div>
      <GlossaryIndex lang="en" basePath="/en/resources/glossary" />
    </div>
  </section>
</Base>
