---
// CHIMERA AI — FAQ (EN). Visible Q&A + FAQPage JSON-LD (GEO, IA §4.1).
import Base from "@layouts/Base.astro";
import FaqList from "@components/FaqList.astro";
import { getFaq } from "@/lib/content";

const entries = await getFaq("en");
const strip = (md: string) =>
  md
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/[*_>#`]/g, "")
    .replace(/\s+/g, " ")
    .trim();
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: entries.map((e) => ({
    "@type": "Question",
    name: e.data.question,
    acceptedAnswer: { "@type": "Answer", text: strip(e.body ?? "") },
  })),
};
---

<Base
  title="Frequently Asked Questions · Chimera AI"
  description="The most frequent questions on security, ownership, hardware and process — with answers."
  jsonLd={[faqLd]}
>
  <section class="section on-light">
    <div class="wrap" style="display:flex;flex-direction:column;gap:32px">
      <div style="max-width:680px;display:flex;flex-direction:column;gap:16px">
        <div class="mono-label">Resources · FAQ</div>
        <h1 class="h-section">Frequently asked questions</h1>
        <p class="lede">The most frequent questions on security, ownership, hardware and process.</p>
      </div>
      <FaqList lang="en" />
    </div>
  </section>
</Base>
