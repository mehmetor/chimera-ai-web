---
// CHIMERA AI — homepage (EN). Same sections, English dictionary.
import Base from "@layouts/Base.astro";
import Hero from "@components/sections/Hero.astro";
import Problem from "@components/sections/Problem.astro";
import Lines from "@components/sections/Lines.astro";
import Platform from "@components/sections/Platform.astro";
import DevOps from "@components/sections/DevOps.astro";
import App from "@components/sections/App.astro";
import Start from "@components/sections/Start.astro";
import Refs from "@components/sections/Refs.astro";
import Resources from "@components/sections/Resources.astro";
import About from "@components/sections/About.astro";
import Contact from "@components/sections/Contact.astro";
import { useTranslations } from "@i18n/utils";
import { SITE } from "../../site";

const t = useTranslations("en");

const productLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Chimera AI",
  brand: { "@type": "Brand", name: SITE.name },
  manufacturer: { "@type": "Organization", name: SITE.org },
  description:
    "A closed-circuit enterprise AI platform that runs on your own servers, leaks no data to external clouds, and is built on an open-source stack.",
  category: "Enterprise AI Platform",
  url: `${SITE.url}/en`,
  hasVariant: t.lines.items.map((l) => ({
    "@type": "Product",
    name: `Chimera AI ${l.name}`,
    description: l.d,
  })),
};
---

<Base
  title="Chimera AI — Artificial intelligence. Within your boundaries, under your control."
  description="A closed-circuit enterprise AI platform that runs on your own servers, leaks no data to external clouds, and feeds on your organization's own knowledge. Not a subscription — your permanent property."
  translated={true}
  routeKey="home"
  jsonLd={[productLd]}
>
  <Hero t={t} />
  <Problem t={t} />
  <Lines t={t} lang="en" />
  <Platform t={t} />
  <DevOps t={t} />
  <App t={t} />
  <Start t={t} />
  <Refs t={t} />
  <Resources t={t} lang="en" hubHref="/en/resources" />
  <About t={t} />
  <Contact t={t} />
</Base>
