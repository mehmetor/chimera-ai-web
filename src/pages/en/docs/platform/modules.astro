---
// CHIMERA AI — Docs · Platform · Modules (EN). DocsShell.
import DocsShell from "@layouts/DocsShell.astro";
import Frame from "@components/Frame.astro";
import ModuleIcon from "@components/ModuleIcon.astro";
import { contactSlug } from "@i18n/routes";
import { SITE } from "@/site";
import { MODULES, ADVANCED_MODULES, ARCHITECTURE_HONESTY, MODULE_RULES, CAPACITY_NOTE } from "@/data/modules.en";

const tierLabel: Record<string, string> = { zorunlu: "Mandatory core", secmeli: "Optional", genisleme: "Expansion" };

const itemListLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Chimera AI Platform modules",
  itemListElement: MODULES.map((m, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: `${m.code} — ${m.name}`,
    description: m.summary,
    url: `${SITE.url}/en/docs/platform/modules#${m.code.toLowerCase()}`,
  })),
};
---

<DocsShell
  title="Platform Modules (M0–M6) · Chimera AI"
  description="Chimera AI Platform module catalog: core platform, knowledge management (RAG), secure code assistant, reasoning, visual document processing, Turkish chatbot, data analysis — what each does, its definition of done and honest limits."
  translated={true}
  altPair={{ tr: "/dokumanlar/platform/moduller", en: "/en/docs/platform/modules" }}
  jsonLd={[itemListLd]}
>
  <div style="display:flex;flex-direction:column;gap:36px">
    <div style="display:flex;flex-direction:column;gap:14px">
      <div class="mono-label">Platform · Module Catalog</div>
      <h1>What you are buying: module by module.</h1>
      <p class="lede" style="max-width:720px">
        Chimera AI is modular. M0 is the mandatory core; the remaining modules are added to need. Below,
        for each module, is what it does, what it includes, its definition of done and its honest limits.
      </p>
    </div>

    <Frame style="padding:28px 30px;display:flex;flex-direction:column;gap:14px;background:var(--card-light)">
      <span class="mono-label" style="color:var(--bronze-ink)">Honest frame · Triadic architecture</span>
      <p style="font-size:calc(17px * var(--ts));font-weight:600">{ARCHITECTURE_HONESTY.triad.join("  +  ")}</p>
      <p class="body-dim" style="font-size:calc(15.5px * var(--ts))">
        Capabilities shipped today: <strong>{ARCHITECTURE_HONESTY.shippedToday}</strong>. {ARCHITECTURE_HONESTY.roadmap}
      </p>
    </Frame>

    <ul style="display:flex;flex-direction:column;gap:10px;max-width:760px;list-style:none;padding:0;margin:0">
      {
        MODULE_RULES.map((r) => (
          <li class="body-dim" style="font-size:calc(15px * var(--ts));display:flex;gap:12px">
            <span style="width:7px;height:7px;background:var(--bronze);flex:none;margin-top:9px" />
            <span>{r}</span>
          </li>
        ))
      }
    </ul>

    <div style="display:flex;flex-direction:column;gap:20px">
      {
        MODULES.map((m) => (
          <Frame id={m.code.toLowerCase()} style="padding:30px 32px;display:flex;flex-direction:column;gap:18px;scroll-margin-top:84px">
            <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
              <div class="icon-tile">
                <ModuleIcon code={m.code} />
              </div>
              <div style="display:flex;flex-direction:column;gap:2px">
                <span class="module-code">{m.code}</span>
                <h2 class="h-card" style="font-size:calc(22px * var(--ts))">{m.name}</h2>
              </div>
              <span style="margin-left:auto;font-family:var(--font-mono);font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--n-500);border:1.5px solid rgba(21,19,14,0.18);border-radius:3px;padding:4px 9px">
                {tierLabel[m.tier]}
              </span>
            </div>
            <p style="font-size:calc(16px * var(--ts));color:var(--n-700)">{m.summary}</p>
            <p class="body-dim" style="font-size:calc(14.5px * var(--ts))">
              <strong style="color:var(--bronze-ink)">For whom:</strong> {m.forWho}
            </p>
            <div class="module-cols">
              <div>
                <span class="module-col-head">What's included</span>
                <ul class="module-ul">{m.includes.map((x) => <li>{x}</li>)}</ul>
              </div>
              <div>
                <span class="module-col-head">Definition of done</span>
                <ul class="module-ul">{m.delivers.map((x) => <li>{x}</li>)}</ul>
              </div>
              <div>
                <span class="module-col-head">Limits · honesty</span>
                <ul class="module-ul">{m.limits.map((x) => <li>{x}</li>)}</ul>
              </div>
            </div>
          </Frame>
        ))
      }
    </div>

    <div style="display:flex;flex-direction:column;gap:16px">
      <h2 class="h-card" style="font-size:calc(22px * var(--ts))">Advanced modules</h2>
      <p class="body-dim" style="max-width:680px;font-size:calc(15px * var(--ts))">
        Expansion items added as the platform matures. Each is handled with its own scope.
      </p>
      <div class="grid-2">
        {
          ADVANCED_MODULES.map((a) => (
            <div class="card" style="gap:8px">
              <div style="display:flex;align-items:center;gap:10px">
                <h3 class="h-card" style="font-size:calc(16.5px * var(--ts))">{a.name}</h3>
                {a.roadmap && (
                  <span style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.06em;text-transform:uppercase;color:var(--terra-ink);border:1.5px solid var(--terra);border-radius:3px;padding:2px 7px">
                    Roadmap
                  </span>
                )}
              </div>
              <p class="body-dim" style="font-size:calc(14.5px * var(--ts))">{a.what}</p>
            </div>
          ))
        }
      </div>
    </div>

    <Frame style="padding:24px 28px;display:flex;flex-direction:column;gap:8px;background:var(--card-light)">
      <span class="mono-label" style="color:var(--bronze-ink)">Hardware</span>
      <p class="body-dim" style="font-size:calc(15px * var(--ts))">{CAPACITY_NOTE}</p>
    </Frame>

    <div style="display:flex;gap:14px;flex-wrap:wrap">
      <a class="btn btn-primary" href={contactSlug("en")}>Request an Architecture Pre-Analysis</a>
      <a class="btn btn-ghost" href="/en/docs/platform/how-it-works">How it works</a>
    </div>
  </div>
</DocsShell>

<style>
  .module-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    border-top: 1.5px solid rgba(21, 19, 14, 0.12);
    padding-top: 18px;
  }
  .module-col-head {
    display: block;
    font-family: var(--font-mono);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--n-500);
    margin-bottom: 10px;
  }
  .module-ul {
    margin: 0;
    padding-left: 18px;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .module-ul li {
    font-size: calc(14px * var(--ts));
    color: var(--n-600);
    line-height: 1.5;
  }
  @media (max-width: 880px) {
    .module-cols {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
</style>
