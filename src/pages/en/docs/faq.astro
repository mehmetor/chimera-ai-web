---
// CHIMERA AI — Docs · FAQ (EN). Visible Q&A + FAQPage JSON-LD (GEO, IA §4.1). DocsShell.
import DocsShell from "@layouts/DocsShell.astro";
import FaqList from "@components/FaqList.astro";
import { getFaq } from "@/lib/content";

const entries = await getFaq("en");
const strip = (md: string) =>
  md
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/[*_>#`]/g, "")
    .replace(/\s+/g, " ")
    .trim();
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: entries.map((e) => ({
    "@type": "Question",
    name: e.data.question,
    acceptedAnswer: { "@type": "Answer", text: strip(e.body ?? "") },
  })),
};
---

<DocsShell
  title="Frequently Asked Questions · Chimera AI"
  description="The most frequently asked questions and answers about security, licensing, hardware, and process."
  translated={true}
  altPair={{ tr: "/dokumanlar/sss", en: "/en/docs/faq" }}
  jsonLd={[faqLd]}
>
  <div class="mono-label">FAQ</div>
  <h1 style="margin-top:14px">Frequently asked questions</h1>
  <p class="lede" style="margin-top:16px;max-width:680px">The most common questions about security, licensing, hardware, and process.</p>
  <div style="margin-top:32px">
    <FaqList lang="en" />
  </div>
</DocsShell>
