<DocsShell
  title="Dokümanlar · Chimera AI"
  description="Chimera AI teknik dokümanları: platform modülleri, mimari, güvenlik, kavram sözlüğü, SSS, benchmark raporları ve blog."
  translated={true}
  altPair={{ tr: "/dokumanlar", en: "/en/docs" }}
>
  <div class="mono-label">Dokümanlar</div>
  <h1 style="margin-top:14px">Chimera AI'ı derinlemesine.</h1>
  <p class="lede" style="margin-top:16px;max-width:680px">
    Platform modülleri, mimari, güvenlik, kavramlar ve raporlar. Soldaki menüden gezinin ya da
    aşağıdan başlayın.
  </p>
  <div class="grid-2" style="margin-top:36px">
    {
      cards.map((c) => (
        <a class="card" href={c.href} style="gap:8px;text-decoration:none;color:inherit">
          <h2 class="h-card" style="font-size:calc(18px * var(--ts))">{c.label}</h2>
          <p class="body-dim" style="font-size:calc(14.5px * var(--ts))">{c.desc}</p>
