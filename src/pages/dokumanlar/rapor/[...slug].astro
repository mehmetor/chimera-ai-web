---
// CHIMERA AI — Dokümanlar · Benchmark Raporu detay (TR). DocsShell + TechArticle JSON-LD (GEO).
import { render, type CollectionEntry } from "astro:content";
import DocsShell from "@layouts/DocsShell.astro";
import { getReports, entrySlug } from "@/lib/content";
import { SITE } from "@/site";

export async function getStaticPaths() {
  const reports = await getReports("tr");
  return reports.map((entry) => ({ params: { slug: entrySlug(entry.id) }, props: { entry } }));
}

interface Props {
  entry: CollectionEntry<"reports">;
}
const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const slug = entrySlug(entry.id);
const url = `${SITE.url}/dokumanlar/rapor/${slug}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: entry.data.title,
  description: entry.data.summary,
  datePublished: entry.data.date.toISOString(),
  dateModified: entry.data.date.toISOString(),
  inLanguage: "tr-TR",
  about: "On-premise açık kaynak LLM ve donanım karşılaştırması",
  author: { "@type": "Organization", name: SITE.org },
  publisher: { "@type": "Organization", name: SITE.org },
  mainEntityOfPage: url,
  url,
};

const meta = `Geçerlilik: ${entry.data.validity}`;
---

<DocsShell
  title={`${entry.data.title} · Chimera AI`}
  description={entry.data.summary}
  crumb={entry.data.title}
  ogType="article"
  jsonLd={[jsonLd]}
>
  <div class="mono-label">Benchmark Raporu</div>
  <h1 style="margin-top:12px">{entry.data.title}</h1>
  <p style="font-family:var(--font-mono);font-size:12.5px;letter-spacing:0.05em;color:var(--n-500);margin-top:10px">{meta}</p>
  <article class="prose" style="margin-top:24px">
    <Content />
  </article>
</DocsShell>
