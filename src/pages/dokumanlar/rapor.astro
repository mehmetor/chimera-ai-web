---
// CHIMERA AI — Dokümanlar · Benchmark Raporları indeksi (TR). DocsShell.
import DocsShell from "@layouts/DocsShell.astro";
import { getReports, entrySlug } from "@/lib/content";

const reports = await getReports("tr");
---

<DocsShell
  title="Benchmark Raporları — Açık kaynak LLM & donanım · Chimera AI"
  description="Her ay yenilenen on-premise açık kaynak LLM ve donanım karşılaştırması. Model/donanım tavsiyesinin kanonik dayanağı."
  translated={false}
>
  <div style="display:flex;flex-direction:column;gap:32px">
    <div style="max-width:700px;display:flex;flex-direction:column;gap:16px">
      <div class="mono-label">Benchmark Raporu</div>
      <h1>Benchmark raporları</h1>
      <p class="lede">
        Kapalı ağda çalıştırılabilen açık kaynak modellerin ve donanımların aylık karşılaştırması —
        model ve donanım önerilerimizin dayanağı.
      </p>
    </div>

    <div style="display:flex;flex-direction:column;gap:16px;max-width:820px">
      {
        reports.map((r) => (
          <a class="card" href={`/dokumanlar/rapor/${entrySlug(r.id)}`} style="gap:10px;text-decoration:none;color:inherit">
            <span style="font-family:var(--font-mono);font-size:11.5px;letter-spacing:0.07em;text-transform:uppercase;color:var(--bronze-ink)">
              {r.data.validity}
            </span>
            <h2 class="h-card" style="font-size:calc(20px * var(--ts))">{r.data.title}</h2>
            <p class="body-dim" style="font-size:calc(15px * var(--ts))">{r.data.summary}</p>
          </a>
        ))
      }
    </div>
  </div>
</DocsShell>
