---
// CHIMERA AI — Dokümanlar · SSS (TR). Görünür Q&A + FAQPage JSON-LD (GEO, IA §4.1). DocsShell.
import DocsShell from "@layouts/DocsShell.astro";
import FaqList from "@components/FaqList.astro";
import { getFaq } from "@/lib/content";

const entries = await getFaq("tr");
const strip = (md: string) =>
  md
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/[*_>#`]/g, "")
    .replace(/\s+/g, " ")
    .trim();
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: entries.map((e) => ({
    "@type": "Question",
    name: e.data.question,
    acceptedAnswer: { "@type": "Answer", text: strip(e.body ?? "") },
  })),
};
---

<DocsShell
  title="Sıkça Sorulan Sorular · Chimera AI"
  description="Güvenlik, lisans, donanım ve süreç hakkında en sık sorulan sorular ve yanıtları."
  translated={true}
  altPair={{ tr: "/dokumanlar/sss", en: "/en/docs/faq" }}
  jsonLd={[faqLd]}
>
  <div class="mono-label">SSS</div>
  <h1 style="margin-top:14px">Sıkça sorulan sorular</h1>
  <p class="lede" style="margin-top:16px;max-width:680px">Güvenlik, lisans, donanım ve süreç hakkında en sık gelen sorular.</p>
  <div style="margin-top:32px">
    <FaqList lang="tr" />
  </div>
</DocsShell>
