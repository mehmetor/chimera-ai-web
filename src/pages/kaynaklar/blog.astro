---
// CHIMERA AI — Blog indeksi (TR).
import Base from "@layouts/Base.astro";
import BlogList from "@components/BlogList.astro";
---

<Base
  title="Blog · Chimera AI"
  description="Aylık model ve donanım benchmark notları, saha gözlemleri ve kapalı devre yapay zeka üzerine mimari yazılar."
>
  <section class="section on-light">
    <div class="wrap" style="display:flex;flex-direction:column;gap:32px">
      <div style="max-width:680px;display:flex;flex-direction:column;gap:16px">
        <div class="mono-label">Kaynaklar · Blog</div>
        <h1 class="h-section">Blog</h1>
        <p class="lede">Benchmark notları, saha gözlemleri ve kapalı devre AI üzerine mimari yazılar.</p>
      </div>
      <BlogList lang="tr" basePath="/kaynaklar/blog" emptyLabel="Yakında ilk yazılar yayımlanacak." />
    </div>
  </section>
</Base>
