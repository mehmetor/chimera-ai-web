---
// CHIMERA AI — Blog makalesi (TR). BlogPosting JSON-LD (GEO, IA §4.1).
import { render, type CollectionEntry } from "astro:content";
import Article from "@layouts/Article.astro";
import { getBlog, entrySlug } from "@/lib/content";
import { SITE } from "../../../site";

export async function getStaticPaths() {
  const posts = await getBlog("tr");
  return posts.map((entry) => ({ params: { slug: entrySlug(entry.id) }, props: { entry } }));
}

interface Props {
  entry: CollectionEntry<"blog">;
}
const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const slug = entrySlug(entry.id);
const url = `${SITE.url}/kaynaklar/blog/${slug}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.pubDate.toISOString(),
  dateModified: (entry.data.updated ?? entry.data.pubDate).toISOString(),
  inLanguage: "tr-TR",
  author: { "@type": "Organization", name: SITE.org },
  publisher: { "@type": "Organization", name: SITE.org },
  mainEntityOfPage: url,
  url,
};
const meta = entry.data.pubDate.toLocaleDateString("tr-TR", { year: "numeric", month: "long", day: "numeric" });
---

<Article
  title={entry.data.title}
  description={entry.data.description}
  kicker="Blog"
  backHref="/kaynaklar/blog"
  backLabel="Tüm yazılar"
  meta={meta}
  jsonLd={[jsonLd]}
>
  <Content />
</Article>
