---
// CHIMERA AI — SSS (TR). Görünür Q&A + FAQPage JSON-LD (GEO, IA §4.1).
import Base from "@layouts/Base.astro";
import FaqList from "@components/FaqList.astro";
import { getFaq } from "@/lib/content";

const entries = await getFaq("tr");
const strip = (md: string) =>
  md
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/[*_>#`]/g, "")
    .replace(/\s+/g, " ")
    .trim();
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: entries.map((e) => ({
    "@type": "Question",
    name: e.data.question,
    acceptedAnswer: { "@type": "Answer", text: strip(e.body ?? "") },
  })),
};
---

<Base
  title="Sıkça Sorulan Sorular · Chimera AI"
  description="Güvenlik, lisans, donanım ve süreç hakkında en sık sorulan sorular ve yanıtları."
  jsonLd={[faqLd]}
>
  <section class="section on-light">
    <div class="wrap" style="display:flex;flex-direction:column;gap:32px">
      <div style="max-width:680px;display:flex;flex-direction:column;gap:16px">
        <div class="mono-label">Kaynaklar · SSS</div>
        <h1 class="h-section">Sıkça sorulan sorular</h1>
        <p class="lede">Güvenlik, lisans, donanım ve süreç hakkında en sık gelen sorular.</p>
      </div>
      <FaqList lang="tr" />
    </div>
  </section>
</Base>
