---
// CHIMERA AI — Benchmark Raporu detay (TR). TechArticle JSON-LD (GEO).
import { render, type CollectionEntry } from "astro:content";
import Article from "@layouts/Article.astro";
import { getReports, entrySlug } from "@/lib/content";
import { SITE } from "../../../site";

export async function getStaticPaths() {
  const reports = await getReports("tr");
  return reports.map((entry) => ({ params: { slug: entrySlug(entry.id) }, props: { entry } }));
}

interface Props {
  entry: CollectionEntry<"reports">;
}
const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const slug = entrySlug(entry.id);
const url = `${SITE.url}/kaynaklar/rapor/${slug}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: entry.data.title,
  description: entry.data.summary,
  datePublished: entry.data.date.toISOString(),
  dateModified: entry.data.date.toISOString(),
  inLanguage: "tr-TR",
  about: "On-premise açık kaynak LLM ve donanım karşılaştırması",
  author: { "@type": "Organization", name: SITE.org },
  publisher: { "@type": "Organization", name: SITE.org },
  mainEntityOfPage: url,
  url,
};
---

<Article
  title={entry.data.title}
  description={entry.data.summary}
  kicker="Benchmark Raporu"
  backHref="/kaynaklar/rapor"
  backLabel="Tüm raporlar"
  meta={`Geçerlilik: ${entry.data.validity}`}
  jsonLd={[jsonLd]}
>
  <Content />
</Article>
