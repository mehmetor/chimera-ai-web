---
// CHIMERA AI — Platform · Modül Kataloğu (TR). Kaynak: src/data/modules.ts (DCN katalog damıtımı).
import Base from "@layouts/Base.astro";
import Frame from "@components/Frame.astro";
import ModuleIcon from "@components/ModuleIcon.astro";
import { contactSlug } from "@i18n/routes";
import { SITE } from "../../site";
import {
  MODULES,
  ADVANCED_MODULES,
  ARCHITECTURE_HONESTY,
  MODULE_RULES,
  CAPACITY_NOTE,
} from "@/data/modules";

const tierLabel: Record<string, string> = {
  zorunlu: "Zorunlu temel",
  secmeli: "Seçmeli",
  genisleme: "Genişleme",
};

// ItemList JSON-LD (modüller) — GEO.
const itemListLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Chimera AI Platform modülleri",
  itemListElement: MODULES.map((m, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: `${m.code} — ${m.name}`,
    description: m.summary,
    url: `${SITE.url}/platform/moduller#${m.code.toLowerCase()}`,
  })),
};
const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Chimera AI", item: SITE.url },
    { "@type": "ListItem", position: 2, name: "Platform", item: `${SITE.url}/platform` },
    { "@type": "ListItem", position: 3, name: "Modüller", item: `${SITE.url}/platform/moduller` },
  ],
};
---

<Base
  title="Platform Modülleri (M0–M6) · Chimera AI"
  description="Chimera AI Platform modül kataloğu: çekirdek platform, bilgi yönetimi (RAG), güvenli kod asistanı, akıl yürütme, görsel doküman işleme, Türkçe chatbot, veri analizi. Her modülün ne yaptığı, teslim kriterleri ve dürüst sınırları."
  routeKey="platform"
  jsonLd={[itemListLd, breadcrumb]}
>
  <section class="section on-light" style="--accent:var(--bronze);--accent-ink:var(--bronze-ink);--accent-on-dark:var(--bronze-on-dark)">
    <div class="wrap" style="display:flex;flex-direction:column;gap:40px">
      <a class="btn-line" href="/platform" style="align-self:flex-start">← Platform</a>

      <div style="max-width:720px;display:flex;flex-direction:column;gap:16px">
        <div class="mono-label">Platform · Modül Kataloğu</div>
        <h1 class="h-section">Ne satın alıyorsunuz: modül modül.</h1>
        <p class="lede">
          Chimera AI modülerdir. M0 zorunlu temeldir; kalan modüller ihtiyaca göre eklenir. Aşağıda her
          modülün ne yaptığı, neyi içerdiği, “bitti” tanımı ve dürüst sınırları var.
        </p>
      </div>

      {/* Dürüstlük çerçevesi — üçlü mimari */}
      <Frame style="padding:28px 30px;display:flex;flex-direction:column;gap:14px;background:var(--card-light)">
        <span class="mono-label" style="color:var(--bronze-ink)">Dürüst çerçeve · Üçlü mimari</span>
        <p style="font-size:calc(17px * var(--ts));font-weight:600">
          {ARCHITECTURE_HONESTY.triad.join("  +  ")}
        </p>
        <p class="body-dim" style="font-size:calc(15.5px * var(--ts))">
          Bugün teslim edilen yetenekler: <strong>{ARCHITECTURE_HONESTY.shippedToday}</strong>.
          {" "}{ARCHITECTURE_HONESTY.roadmap}
        </p>
      </Frame>

      {/* Kurallar */}
      <ul style="display:flex;flex-direction:column;gap:10px;max-width:760px;list-style:none;padding:0;margin:0">
        {
          MODULE_RULES.map((r) => (
            <li class="body-dim" style="font-size:calc(15px * var(--ts));display:flex;gap:12px">
              <span style="width:7px;height:7px;background:var(--bronze);flex:none;margin-top:9px" />
              <span>{r}</span>
            </li>
          ))
        }
      </ul>

      {/* Modüller */}
      <div style="display:flex;flex-direction:column;gap:20px">
        {
          MODULES.map((m) => (
            <Frame id={m.code.toLowerCase()} style="padding:30px 32px;display:flex;flex-direction:column;gap:18px;scroll-margin-top:84px">
              <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
                <div class="icon-tile">
                  <ModuleIcon code={m.code} />
                </div>
                <div style="display:flex;flex-direction:column;gap:2px">
                  <span class="module-code">{m.code}</span>
                  <h2 class="h-card" style="font-size:calc(22px * var(--ts))">{m.name}</h2>
                </div>
                <span style="margin-left:auto;font-family:var(--font-mono);font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--n-500);border:1.5px solid rgba(21,19,14,0.18);border-radius:3px;padding:4px 9px">
                  {tierLabel[m.tier]}
                </span>
              </div>

              <p style="font-size:calc(16px * var(--ts));color:var(--n-700)">{m.summary}</p>
              <p class="body-dim" style="font-size:calc(14.5px * var(--ts))">
                <strong style="color:var(--bronze-ink)">Kime:</strong> {m.forWho}
              </p>

              <div class="module-cols">
                <div>
                  <span class="module-col-head">İçinde ne var</span>
                  <ul class="module-ul">{m.includes.map((x) => <li>{x}</li>)}</ul>
                </div>
                <div>
                  <span class="module-col-head">“Bitti” tanımı</span>
                  <ul class="module-ul">{m.delivers.map((x) => <li>{x}</li>)}</ul>
                </div>
                <div>
                  <span class="module-col-head">Sınırlar · dürüstlük</span>
                  <ul class="module-ul">{m.limits.map((x) => <li>{x}</li>)}</ul>
                </div>
              </div>
            </Frame>
          ))
        }
      </div>

      {/* İleri modüller */}
      <div style="display:flex;flex-direction:column;gap:16px">
        <h2 class="h-card" style="font-size:calc(22px * var(--ts))">İleri modüller</h2>
        <p class="body-dim" style="max-width:680px;font-size:calc(15px * var(--ts))">
          Platform olgunlaştıkça eklenen genişleme kalemleri. Her biri ayrı kapsamla ele alınır.
        </p>
        <div class="grid-2">
          {
            ADVANCED_MODULES.map((a) => (
              <div class="card" style="gap:8px">
                <div style="display:flex;align-items:center;gap:10px">
                  <h3 class="h-card" style="font-size:calc(16.5px * var(--ts))">{a.name}</h3>
                  {a.roadmap && (
                    <span style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.06em;text-transform:uppercase;color:var(--terra-ink);border:1.5px solid var(--terra);border-radius:3px;padding:2px 7px">
                      Yol haritası
                    </span>
                  )}
                </div>
                <p class="body-dim" style="font-size:calc(14.5px * var(--ts))">{a.what}</p>
              </div>
            ))
          }
        </div>
      </div>

      {/* Donanım notu + CTA */}
      <Frame style="padding:24px 28px;display:flex;flex-direction:column;gap:8px;background:var(--card-light)">
        <span class="mono-label" style="color:var(--bronze-ink)">Donanım</span>
        <p class="body-dim" style="font-size:calc(15px * var(--ts))">{CAPACITY_NOTE}</p>
      </Frame>

      <div style="display:flex;gap:14px;flex-wrap:wrap">
        <a class="btn btn-primary" href={contactSlug("tr")}>Mimari Ön-Analiz talep edin</a>
        <a class="btn btn-ghost" href="/nasil-baslariz">Nasıl başlarız</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .module-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    border-top: 1.5px solid rgba(21, 19, 14, 0.12);
    padding-top: 18px;
  }
  .module-col-head {
    display: block;
    font-family: var(--font-mono);
    font-size: 11.5px;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--n-500);
    margin-bottom: 10px;
  }
  .module-ul {
    margin: 0;
    padding-left: 18px;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .module-ul li {
    font-size: calc(14px * var(--ts));
    color: var(--n-600);
    line-height: 1.5;
  }
  @media (max-width: 880px) {
    .module-cols {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
</style>
