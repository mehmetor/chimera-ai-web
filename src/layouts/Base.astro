---
// CHIMERA AI — temel layout (her sayfanın kabuğu)
// Fontlar self-host (OFL): Inter Variable + IBM Plex Mono — Google CDN yok.
import "@styles/tokens.css";
import "@styles/base.css";
import "@styles/components.css";
import "@fontsource-variable/inter";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "@fontsource/ibm-plex-mono/600.css";

import Seo from "@components/Seo.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import { getLangFromUrl, useTranslations } from "@i18n/utils";
import { SITE, organizationSchema } from "../site";

interface Props {
  title: string;
  description: string;
  translated?: boolean;
  image?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
  jsonLd?: Record<string, unknown>[];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { title, description, translated = false, image, ogType, noindex, jsonLd = [] } = Astro.props;
const allJsonLd = [organizationSchema(), ...jsonLd];
const skipLabel = lang === "tr" ? "İçeriğe geç" : "Skip to content";
---

<!doctype html>
<html lang={lang}>
  <head>
    <Seo
      title={title}
      description={description}
      lang={lang}
      translated={translated}
      image={image}
      ogType={ogType}
      noindex={noindex}
      jsonLd={allJsonLd}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {
      SITE.analyticsDomain && SITE.analyticsSrc && (
        <script is:inline defer data-domain={SITE.analyticsDomain} src={SITE.analyticsSrc} />
      )
    }
  </head>
  <body>
    <a class="skip-link" href="#main">{skipLabel}</a>
    <Nav lang={lang} t={t} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} t={t} />

    {/* İç/karşılaştırma: ?theme=gece|patine|volkanik — public UI yok; üretimde Alaşım kilitli. */}
    <script is:inline>
      (function () {
        try {
          var p = new URLSearchParams(location.search).get("theme");
          var ok = ["gece", "patine", "volkanik"];
          if (p && ok.indexOf(p) >= 0) document.body.classList.add("theme-" + p);
        } catch (e) {}
      })();
    </script>
  </body>
</html>
