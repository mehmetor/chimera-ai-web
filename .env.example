# CHIMERA AI — ortam değişkenleri örneği. Kopyala: cp .env.example .env
# PUBLIC_ önekli değişkenler istemci paketine girer (gizli değer KOYMA).

# Mimari Ön-Analiz formu hedefi (statik + form servisi). Boşsa form mailto'ya düşer.
# Örn. Formspree/Basin/kendi fonksiyonun: https://...
PUBLIC_FORM_ENDPOINT=

# Gizlilik-dostu analitik (Plausible/Umami). İkisi de doluysa script yüklenir.
# Örn. domain: chimera-ai.com.tr · src: https://plausible.io/js/script.js
PUBLIC_ANALYTICS_DOMAIN=
PUBLIC_ANALYTICS_SRC=
