# CHIMERA AI — ortam değişkenleri örneği. Kopyala: cp .env.example .env
# PUBLIC_ önekli değişkenler istemci paketine girer (gizli değer KOYMA).

# --- Mimari Ön-Analiz formu (CTA) ---
# Cloudflare Worker route'u. Boşsa form mailto'ya düşer (kullanıcının mail istemcisi).
# Kurulum: cloudflare/form-worker/README.md
# Örn: https://chimera-ai.com.tr/api/on-analiz
PUBLIC_FORM_ENDPOINT=

# --- Analitik (Umami self-host, çerezsiz) ---
# İkisi de doluysa <script defer data-website-id src> head'e girer. Tek instance tüm siteler için.
# WEBSITE_ID: Umami panelinde site eklenince verilen UUID.
# SRC: Umami örneğinin script'i, örn. https://analitik.dcnextgen.com.tr/script.js
PUBLIC_ANALYTICS_WEBSITE_ID=
PUBLIC_ANALYTICS_SRC=

# --- Google Search Console (SEO — analitikten ayrı) ---
# HTML meta yöntemiyle doğrulama token'ı (content="..." kısmı). DNS yöntemi seçilirse boş bırak.
PUBLIC_GSC_VERIFICATION=
