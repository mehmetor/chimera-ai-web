{
  "name": "chimera-ai-web",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Chimera AI ürün sitesi (chimera-ai.com.tr) — Astro SSG",
  "scripts": {
    "dev": "astro dev",
    "start": "astro preview --host 0.0.0.0 --port ${PORT:-4321}",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "format": "prettier --write \"src/**/*.{astro,ts,css,md,mdx}\"",
    "lint": "eslint \"src/**/*.{astro,ts}\"",
    "og": "node scripts/make-og.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.2.0",
    "@astrojs/sitemap": "^3.3.0",
    "@fontsource-variable/inter": "^5.2.0",
    "@fontsource/ibm-plex-mono": "^5.2.0",
    "astro": "^5.8.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "eslint": "^9.20.0",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.5.0",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.0"
  }
}
